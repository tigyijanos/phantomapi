{
  "Phantom": {
    // Leave empty to let PhantomAPI pick the OS-appropriate default.
    // Windows host: "codex.cmd"
    // Linux/macOS/container: "codex"
    "CliCommand": "",

    // Preferred model for request-time Codex execution.
    // Common options:
    // - "gpt-5.4"
    // - "gpt-5.3-codex-spark"
    "Model": "gpt-5.3-codex-spark",

    // Common reasoning options:
    // - "low"    fastest
    // - "medium" balanced
    // - "high"   slower
    // - "xhigh"  slowest
    // Avoid "minimal" here; the current tool mix may reject it.
    "ReasoningEffort": "medium",

    // Advanced override. Leave empty to compose the CLI arguments automatically
    // from CliCommand + Model + ReasoningEffort.
    // Example:
    // "--dangerously-bypass-approvals-and-sandbox exec -m gpt-5.4 -c model_reasoning_effort=low --skip-git-repo-check --output-last-message {output} -"
    "CliArgumentsTemplate": "",

    // Keep a warm codex app-server alive and reuse it across requests.
    "UseWarmAppServer": true,

    // Reuse successful `codex exec` sessions through `codex exec resume`.
    "UseExecSessionPool": true,

    // If warm mode fails, fall back to a one-off `codex exec` call.
    "FallbackToColdExecution": true,

    // How long to wait for final warm-turn text-bearing notifications
    // before giving up and falling back to cold execution.
    "WarmTurnGraceSeconds": 4,

    // Default fast-mode toggle when request does not set fastMode/fast.
    // Set true if you want the backend to prefer low-reasoning/flex model behavior by default.
    "FastModeEnabled": false,

    // Fast-mode profile overrides.
    // Fast mode keeps model and service tier explicit so you can avoid changing global model.
    "FastModeModel": "gpt-5.3-codex-spark",
    "FastModeReasoningEffort": "low",
    "FastModeServiceTier": "fast",

    // Optional service tier for regular mode. Leave empty for default behavior.
    "NormalServiceTier": "",

    // Total timeout for one Codex request.
    "CliTimeoutSeconds": 180
  }
}
